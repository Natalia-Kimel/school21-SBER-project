# По умолчанию MVP работает автономно: локальный RAG выбирает и синтезирует
# ответ из доступных фрагментов документов.
LLM_PROVIDER=local

# Для реальной генеративной модели через корпоративный OpenAI-compatible шлюз:
# LLM_PROVIDER=openai_compatible
# LLM_API_URL=https://your-corporate-llm-gateway.example/v1/chat/completions
# LLM_API_KEY=replace_me
# LLM_MODEL=your-model-name
# LLM_VERIFY_SSL=true
